    </link>

    <link name='red_lens'>
      <pose>-0.018681 0.002156 0.21022 0 -0 0</pose>
      <visual name='visual'>
        <geometry>
          <sphere><radius>0.025</radius></sphere>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
          <emissive>1 0 0 1</emissive>
        </material>
      </visual>
    </link>

    <joint name="green_joint" type="fixed">
      <parent>case</parent> <child>green_lens</child>
    </joint>
    <joint name="yellow_joint" type="fixed">
      <parent>case</parent> <child>yellow_lens</child>
    </joint>
    <joint name="red_joint" type="fixed">
      <parent>case</parent> <child>red_lens</child>

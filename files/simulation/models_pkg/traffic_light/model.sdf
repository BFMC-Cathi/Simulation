<?xml version='1.0'?>
<sdf version="1.8">
  <model name='traffic_light'>
    <static>true</static>

    <link name='case'>
      <pose>-0.048681 0.002156 0 0 -0 0</pose>
      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://traffic_light/meshes/traffic_light_case.dae</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
          <box>
            <size>0.25 0.25 0.75</size>
          </box>
        </geometry>
      </collision>
    </link>

    <link name='green_lens'>
      <pose>-0.018681 0.002156 0.09102 0 -0 0</pose>
      <visual name='visual'>
        <geometry>
          <sphere><radius>0.025</radius></sphere>
        </geometry>
        <material>
          <ambient>0 1 0 1</ambient>
          <diffuse>0 1 0 1</diffuse>
          <emissive>0 1 0 1</emissive>
        </material>
      </visual>
    </link>

    <link name='yellow_lens'>
      <pose>-0.018681 0.002156 0.15 0 -0 0</pose>
      <visual name='visual'>
        <geometry>
          <sphere><radius>0.025</radius></sphere>
        </geometry>
        <material>
          <ambient>1 1 0 1</ambient>
          <diffuse>1 1 0 1</diffuse>
          <emissive>1 1 0 1</emissive>
        </material>
